@inproceedings{10.1145/3779657.3779668,
author = {Luy Fook, Harlene and Cagas, Micah Angela and Aquilino, Althea and Pangan, Efraim Jededia and Peralta, Joan and Clemente, Jhun Russel},
title = {A Systematic Literature Review on the Application of Scrum in Application Development: An Analysis of Scrum in Application Development},
year = {2026},
isbn = {9798400715778},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3779657.3779668},
doi = {10.1145/3779657.3779668},
abstract = {The rapid growth of the software development industry has accelerated the adoption of Agile methodologies, which emphasize adaptability, collaboration, and continuous improvement in delivering high-quality applications. Among these, Scrum has become one of the most widely implemented frameworks, enabling teams to manage complex projects through iterative processes, defined roles, and continuous feedback. Despite its popularity, organizations face recurring challenges in fully optimizing Scrum's potential, particularly in planning, communication, team commitment, and technical sustainability. This study presents a systematic literature review on the application of Scrum in software development. The review draws from peer-reviewed articles published between 2019 and 2025, sourced from IEEE Xplore and ScienceDirect databases. Findings reveal that Scrum is widely used to enhance agile project management, enable incremental software delivery, promote cross-functional collaboration, and support customer-driven development. However, several challenges persist in its implementation, including issues with long-term planning, team commitment, communication gaps, technical maintenance, and limitations faced by small organizations. While Scrum offers key benefits such as adaptability, improved team collaboration, and increased efficiency, it also presents limitations in large-scale settings and requires significant resource and expertise investment. The study concludes that although Scrum is a valuable framework for modern software development, its success depends on contextual adaptation and team readiness. Recommendations for future research include broader longitudinal studies, exploration of hybrid methodologies, and deeper investigation into underrepresented implementation issues.},
booktitle = {Proceedings of the 2025 7th World Symposium on Software Engineering},
pages = {68–73},
numpages = {6},
keywords = {Advantages of Scrum, Challenges of Scrum in application development, Scrum, Scrum in application development},
location = {
},
series = {WSSE '25}
}

